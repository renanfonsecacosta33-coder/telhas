{
  "name": "Pedido",
  "type": "object",
  "properties": {
    "data": {
      "type": "string",
      "format": "date",
      "description": "Data de produ\u00e7\u00e3o planejada"
    },
    "vendedor": {
      "type": "string",
      "description": "Nome do vendedor"
    },
    "cliente": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "numero_pedido": {
      "type": "string",
      "description": "N\u00famero do pedido"
    },
    "produto": {
      "type": "string",
      "enum": [
        "TELHA",
        "TELHA + EPS",
        "TELHA + EPS + MANTA",
        "TELHA + EPS + TELHA",
        "TELHA BANDEJA",
        "BOBININHA",
        "CUMEEIRA",
        "PAINEL"
      ],
      "description": "Tipo de produto"
    },
    "modelo": {
      "type": "string",
      "description": "Modelo / especifica\u00e7\u00e3o do produto (ex: TP-40 RVM, Bandeja Branca)"
    },
    "maquina": {
      "type": "string",
      "enum": [
        "TP - 25",
        "TP - 40",
        "ONDULADA",
        "COLONIAL",
        "BANDEJA",
        "DESBOBINADOR",
        "CUMEEIRA",
        "COLAGEM"
      ],
      "description": "M\u00e1quina respons\u00e1vel"
    },
    "bobina_superior_id": {
      "type": "string",
      "description": "ID da bobina superior no estoque"
    },
    "bobina_inferior_id": {
      "type": "string",
      "description": "ID da bobina inferior no estoque"
    },
    "bobina_superior": {
      "type": "string",
      "description": "Texto descritivo da bobina superior (chapa, cor, qualidade)"
    },
    "bobina_inferior": {
      "type": "string",
      "description": "Texto descritivo da bobina inferior"
    },
    "rvm_superior": {
      "type": "string",
      "description": "RVM / Cor superior"
    },
    "rvm_inferior": {
      "type": "string",
      "description": "RVM / Cor inferior"
    },
    "eps": {
      "type": "string",
      "description": "Tipo de EPS (se aplic\u00e1vel)"
    },
    "maquinario_superior": {
      "type": "string",
      "description": "Maquin\u00e1rio superior"
    },
    "maquinario_inferior": {
      "type": "string",
      "description": "Maquin\u00e1rio inferior"
    },
    "kg_superior": {
      "type": "number",
      "description": "KG superior"
    },
    "kg_inferior": {
      "type": "number",
      "description": "KG inferior"
    },
    "kg_total": {
      "type": "number",
      "description": "KG total"
    },
    "metros": {
      "type": "number",
      "description": "Metros do pedido"
    },
    "metragem_mm": {
      "type": "number",
      "description": "Metragem em mil\u00edmetros"
    },
    "quantidade_telhas": {
      "type": "number",
      "description": "Quantidade de telhas"
    },
    "metragem_planejada": {
      "type": "number",
      "description": "Metragem planejada de bobina a ser usada"
    },
    "metragem_utilizada": {
      "type": "number",
      "description": "Metragem real utilizada pelo operador na produ\u00e7\u00e3o"
    },
    "status": {
      "type": "string",
      "enum": [
        "pendente",
        "em_producao",
        "pausado",
        "aguardando_colagem",
        "finalizado",
        "cancelado"
      ],
      "default": "pendente",
      "description": "Status do pedido"
    },
    "data_pedido": {
      "type": "string",
      "format": "date",
      "description": "Data do pedido original"
    },
    "data_prevista": {
      "type": "string",
      "format": "date",
      "description": "Data prevista de entrega"
    },
    "data_finalizacao": {
      "type": "string",
      "format": "date",
      "description": "Data de finaliza\u00e7\u00e3o"
    },
    "unidade": {
      "type": "string",
      "enum": [
        "Matriz AJL",
        "Pinhais",
        "Ivaipor\u00e3",
        "Ponta Grossa"
      ],
      "default": "Matriz AJL",
      "description": "Unidade produtora"
    },
    "isopor_utilizado": {
      "type": "number",
      "description": "Quantidade de pe\u00e7as de isopor utilizadas"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es"
    },
    "tempo_producao_seg": {
      "type": "number",
      "description": "Tempo total em produ\u00e7\u00e3o (segundos acumulados)"
    },
    "tempo_pausa_seg": {
      "type": "number",
      "description": "Tempo total em pausa (segundos acumulados)"
    },
    "tempo_setup_seg": {
      "type": "number",
      "description": "Tempo total em setup de m\u00e1quina (segundos acumulados)"
    },
    "tempo_colagem_seg": {
      "type": "number",
      "description": "Tempo total em colagem (segundos acumulados)"
    },
    "tempo_pausa_colagem_seg": {
      "type": "number",
      "description": "Tempo total em pausa durante colagem (segundos acumulados)"
    },
    "inicio_producao_ts": {
      "type": "string",
      "description": "Timestamp ISO de quando entrou em produ\u00e7\u00e3o (sess\u00e3o atual)"
    },
    "inicio_pausa_ts": {
      "type": "string",
      "description": "Timestamp ISO de quando a pausa atual come\u00e7ou"
    },
    "motivo_pausa": {
      "type": "string",
      "description": "Motivo da pausa atual (setup ou texto livre)"
    },
    "historico_pausas": {
      "type": "string",
      "description": "JSON string com hist\u00f3rico de pausas [{motivo, inicio, fim, segundos}]"
    }
  },
  "required": [
    "data",
    "produto"
  ]
}